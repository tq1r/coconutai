# Coconut AI - Environment Configuration Template
# Copy to .env and fill in your values

# AI Provider Keys (leave blank to use sample responses)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=

# Vercel KV / Upstash Redis (required on Vercel for persistence)
# Set these in Vercel project settings after creating a KV database
KV_REST_API_URL=
KV_REST_API_TOKEN=

# JWT Secret for auth tokens (min 32 chars)
JWT_SECRET=your-jwt-secret-min-32-chars-long

# Roblox OAuth (optional - for account linking)
ROBLOX_CLIENT_ID=
ROBLOX_CLIENT_SECRET=

# Discord Bot (coconut-bot)
DISCORD_TOKEN=your-bot-token
DISCORD_GUILD_ID=your-guild-id
DISCORD_OWNER_ID=your-owner-id
ADMIN_DISCORD_ID=your-admin-discord-id

# API
NEXT_PUBLIC_API_URL=http://localhost:3000
NODE_ENV=development
